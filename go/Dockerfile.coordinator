FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
COPY go.sum* ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 GOFLAGS=-trimpath go build \
    -ldflags='-s -w' -o /out/coordinatord ./cmd/coordinatord

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/coordinatord /coordinatord
EXPOSE 9981
ENTRYPOINT ["/coordinatord"]
